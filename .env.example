# Football IQ App - Environment Variables
# Copy this file to .env and fill in your credentials

# Firebase Configuration
# Get these from: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API-Football (RapidAPI)
# Get from: https://rapidapi.com/api-sports/api/api-football
VITE_RAPIDAPI_KEY=your_rapidapi_key
VITE_RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# NewsData.io
# Get from: https://newsdata.io
VITE_NEWSDATA_API_KEY=your_newsdata_api_key
